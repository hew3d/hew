---
const year = new Date().getFullYear();

const navItems = [
  { label: 'Download', href: '/download' },
  { label: 'Learn', href: '/learn' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Blog', href: '/blog' },
];
---

<footer class="site-footer">
  <div class="container grid">
    <div class="col-brand">
      <a href="/" class="brand">
        <img
          src="/favicon.svg"
          alt=""
          width="24"
          height="24"
          class="brand-mark"
        />
        <span class="brand-word">Hew</span>
      </a>
      <p class="tagline">
        A solids-first 3D modeler with SketchUp's feel — open source, open
        format.
      </p>
      <a class="try-link" href="https://app.hew3d.com">Try in browser →</a>
    </div>

    <nav class="col-nav" aria-label="Footer">
      <h2 class="col-title">Site</h2>
      <ul>
        {
          navItems.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="col-project">
      <h2 class="col-title">Project</h2>
      <ul>
        <li><a href="https://github.com/hew3d/hew">Source</a></li>
        <li><a href="https://github.com/hew3d/hew">License</a></li>
      </ul>
    </div>
  </div>

  <div class="container bottom">
    <p>© {year} Hew.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-2xl);
    padding-block-start: var(--space-xl);
    padding-block-end: var(--space-lg);
    background: var(--color-surface);
  }

  .grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-lg);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    text-decoration: none;
    color: var(--color-text);
    font-weight: var(--font-weight-extrabold);
    font-size: 1.125rem;
    letter-spacing: var(--tracking-tight);
  }

  .tagline {
    margin-top: var(--space-sm);
    max-width: 32ch;
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  .try-link {
    display: inline-block;
    margin-top: var(--space-sm);
    color: var(--color-accent-text);
    text-decoration: none;
    font-weight: var(--font-weight-semibold);
  }

  .try-link:hover {
    color: var(--color-accent);
  }

  .col-title {
    font-size: 0.8125rem;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .col-nav ul,
  .col-project ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .col-nav a,
  .col-project a {
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.9375rem;
  }

  .col-nav a:hover,
  .col-project a:hover {
    color: var(--color-accent-text);
  }

  .bottom {
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 40rem) {
    .grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>
