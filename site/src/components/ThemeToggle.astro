---
// Accessible light/dark toggle. Icons are swapped via CSS `data-theme`
// attribute selectors so no JS is needed for the icon swap itself — the
// inline script only flips the attribute and persists the choice.
---

<button
  id="theme-toggle"
  class="theme-toggle"
  type="button"
  aria-label="Toggle colour theme"
>
  <svg
    class="icon icon-sun"
    viewBox="0 0 24 24"
    width="20"
    height="20"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4.5"></circle>
    <path
      d="M12 2.5v2.25M12 19.25v2.25M4.6 4.6l1.6 1.6M17.8 17.8l1.6 1.6M2.5 12h2.25M19.25 12h2.25M4.6 19.4l1.6-1.6M17.8 6.2l1.6-1.6"
    ></path>
  </svg>
  <svg
    class="icon icon-moon"
    viewBox="0 0 24 24"
    width="20"
    height="20"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-full);
    color: var(--color-text);
    transition: background-color var(--duration-fast) var(--ease-standard);
  }

  .theme-toggle:hover {
    background: var(--color-surface-raised);
  }

  .icon-moon {
    display: none;
  }

  html[data-theme='dark'] .icon-sun {
    display: none;
  }

  html[data-theme='dark'] .icon-moon {
    display: block;
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var root = document.documentElement;
      var next = root.dataset.theme === 'dark' ? 'light' : 'dark';
      root.dataset.theme = next;
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
    });
  })();
</script>
