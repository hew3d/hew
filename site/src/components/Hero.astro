---
import Button from './Button.astro';

interface Cta {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  tagline: string;
  primaryCta: Cta;
  secondaryCta?: Cta;
}

const { eyebrow, title, tagline, primaryCta, secondaryCta } = Astro.props;
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <svg viewBox="0 0 600 600" preserveAspectRatio="xMidYMid slice">
      <defs>
        <pattern
          id="hero-grid"
          width="40"
          height="40"
          patternUnits="userSpaceOnUse"
        >
          <path d="M40 0H0V40" fill="none" stroke="currentColor" stroke-width="1"
          ></path>
        </pattern>
      </defs>
      <rect width="600" height="600" fill="url(#hero-grid)"></rect>
      <g
        transform="translate(440 250) scale(3.4)"
        fill="none"
        stroke="currentColor"
        stroke-width="3"
        stroke-linejoin="round"
        stroke-linecap="round"
      >
        <polygon
          points="0,-34 29.44,-17 29.44,17 0,34 -29.44,17 -29.44,-17"
        ></polygon>
        <line x1="0" y1="0" x2="0" y2="-34"></line>
        <line x1="0" y1="0" x2="-29.44" y2="-17"></line>
        <line x1="0" y1="0" x2="29.44" y2="-17"></line>
      </g>
    </svg>
  </div>

  <div class="container hero-inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    <p class="tagline">{tagline}</p>
    <div class="cta-row">
      <Button href={primaryCta.href} variant="primary" size="lg">
        {primaryCta.label}
      </Button>
      {
        secondaryCta && (
          <Button href={secondaryCta.href} variant="secondary" size="lg">
            {secondaryCta.label}
          </Button>
        )
      }
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-3xl) var(--space-2xl);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    color: var(--color-text);
    opacity: 0.05;
    pointer-events: none;
  }

  .hero-bg svg {
    width: 100%;
    height: 100%;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 42rem;
  }

  .hero-inner .eyebrow {
    margin-bottom: var(--space-sm);
  }

  .tagline {
    margin-top: var(--space-md);
    max-width: 40ch;
    font-size: 1.1875rem;
    color: var(--color-text-muted);
  }

  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  @media (max-width: 30rem) {
    .hero {
      padding-block: var(--space-2xl) var(--space-xl);
    }
  }
</style>
