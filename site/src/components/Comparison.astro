---
interface Item {
  title: string;
  pain: string;
  fix: string;
}

interface Props {
  comparisonTitle: string;
  comparisonIntro?: string;
  comparison: Item[];
}

const { comparisonTitle, comparisonIntro, comparison } = Astro.props;
---

<section class="comparison">
  <div class="container">
    <header class="comparison-head">
      <h2>{comparisonTitle}</h2>
      {comparisonIntro && <p class="intro">{comparisonIntro}</p>}
    </header>

    <div class="items">
      {
        comparison.map((item) => (
          <div class="item">
            <h3>{item.title}</h3>
            <div class="panels">
              <div class="panel panel-pain">
                <p class="panel-label">The problem</p>
                <p>{item.pain}</p>
              </div>
              <svg
                class="arrow"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <line x1="4" y1="12" x2="20" y2="12" />
                <polyline points="14,6 20,12 14,18" />
              </svg>
              <div class="panel panel-fix">
                <p class="panel-label">In Hew</p>
                <p>{item.fix}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .comparison {
    padding-block: var(--space-2xl);
  }

  .comparison-head {
    max-width: 48rem;
    margin-bottom: var(--space-xl);
  }

  .comparison-head .intro {
    margin-top: var(--space-sm);
    font-size: 1.0625rem;
    color: var(--color-text-muted);
  }

  .items {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .item h3 {
    margin-bottom: var(--space-sm);
    font-size: 1.25rem;
  }

  .panels {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-sm);
  }

  .panel {
    align-self: stretch;
    padding: var(--space-md);
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
  }

  .panel > * + * {
    margin-top: var(--space-2xs);
  }

  .panel-label {
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .panel-pain {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .panel-pain .panel-label {
    color: var(--color-text-muted);
  }

  .panel-fix {
    background: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
    border: 1.5px solid var(--color-accent);
    color: var(--color-text);
  }

  .panel-fix .panel-label {
    color: var(--color-accent-text);
  }

  .arrow {
    width: 1.5rem;
    height: 1.5rem;
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 48rem) {
    .panels {
      grid-template-columns: 1fr;
    }

    .arrow {
      justify-self: center;
      transform: rotate(90deg);
    }
  }
</style>
