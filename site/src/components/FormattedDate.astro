---
interface Props {
  date: Date;
}

const { date } = Astro.props;

// Frontmatter dates like `` parse as UTC midnight; format in UTC
// too, or any timezone west of Greenwich renders the previous day.
const formatted = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---

<time datetime={date.toISOString()}>{formatted}</time>
