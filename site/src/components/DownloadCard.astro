---
import Button from './Button.astro';

interface Release {
  id: 'macos' | 'windows' | 'linux';
  label: string;
  available: boolean;
  version?: string;
  downloadUrl?: string;
  formats?: string[];
  note?: string;
}

interface Props {
  release: Release;
}

const { release } = Astro.props;
---

<article
  class="download-card"
  data-os={release.id}
  id={`download-${release.id}`}
>
  <div class="card-head">
    <h3>{release.label}</h3>
    <span class="detected-badge">Detected</span>
  </div>

  {
    release.available ? (
      <div class="body">
        {release.version && <p class="version">Version {release.version}</p>}
        {release.downloadUrl && (
          <Button href={release.downloadUrl} variant="primary">
            Download for {release.label}
          </Button>
        )}
        {release.formats && release.formats.length > 0 && (
          <p class="formats">{release.formats.join(' · ')}</p>
        )}
      </div>
    ) : (
      <div class="body">
        <span class="badge-soon">Coming soon</span>
        {release.note && <p class="note">{release.note}</p>}
        <Button href="https://app.hew3d.com" variant="secondary">
          Use Hew in your browser
        </Button>
      </div>
    )
  }
</article>

<style>
  .download-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-sm);
  }

  .download-card[data-detected] {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--color-accent) 22%, transparent);
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs);
  }

  .detected-badge {
    display: none;
    font-size: 0.6875rem;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent-contrast);
    background: var(--color-accent);
    padding: 0.25em 0.6em;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .download-card[data-detected] .detected-badge {
    display: inline-block;
  }

  .body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .version {
    font-weight: var(--font-weight-semibold);
  }

  .formats {
    font-family: var(--font-family-mono);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .badge-soon {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.3em 0.75em;
    border-radius: var(--radius-full);
  }

  .note {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }
</style>
