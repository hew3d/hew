---
import Button from './Button.astro';

interface Variant {
  arch: string;
  asset: string;
}

interface DownloadRow {
  format: string;
  variants: Variant[];
}

interface Platform {
  // Only ever 'macos' | 'windows' | 'linux', but the JSON import types it
  // as string; it is used solely as a DOM hook for the OS-detection script.
  id: string;
  label: string;
  requires?: string;
  primary: { label: string; asset: string; detail?: string };
  downloads: DownloadRow[];
  note?: string;
}

interface Props {
  platform: Platform;
  version: string;
  repo: string;
}

const { platform, version, repo } = Astro.props;

const assetUrl = (asset: string) =>
  `https://github.com/${repo}/releases/download/v${version}/${asset.replaceAll('{version}', version)}`;

// The primary button already carries the single-variant case (macOS); only
// render the full matrix when there is more than one file to offer.
const showMatrix =
  platform.downloads.length > 1 ||
  platform.downloads.some((row) => row.variants.length > 1);
---

<article
  class="download-card"
  data-os={platform.id}
  id={`download-${platform.id}`}
>
  <div class="card-head">
    <h2>{platform.label}</h2>
    <span class="detected-badge">Your system</span>
  </div>

  {platform.requires && <p class="requires">{platform.requires}</p>}

  <div class="primary">
    <Button href={assetUrl(platform.primary.asset)} variant="primary">
      {platform.primary.label}
    </Button>
    {
      platform.primary.detail && (
        <span class="primary-detail">{platform.primary.detail}</span>
      )
    }
  </div>

  {
    showMatrix && (
      <dl class="matrix">
        {platform.downloads.map((row) => (
          <div class="matrix-row">
            <dt>{row.format}</dt>
            <dd>
              {row.variants.map((v, i) => (
                <>
                  {i > 0 && (
                    <span class="sep" aria-hidden="true">
                      ·
                    </span>
                  )}
                  <a href={assetUrl(v.asset)}>{v.arch}</a>
                </>
              ))}
            </dd>
          </div>
        ))}
      </dl>
    )
  }

  {platform.note && <p class="note">{platform.note}</p>}
</article>

<style>
  .download-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface-raised);
    box-shadow: var(--shadow-sm);
  }

  .download-card[data-detected] {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px
      color-mix(in srgb, var(--color-accent) 22%, transparent);
  }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xs);
  }

  .card-head h2 {
    font-size: 1.375rem;
  }

  .detected-badge {
    display: none;
    font-size: 0.6875rem;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent-contrast);
    background: var(--color-accent);
    padding: 0.25em 0.6em;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .download-card[data-detected] .detected-badge {
    display: inline-block;
  }

  .requires {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    min-height: 2.6em;
  }

  .primary {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2xs);
  }

  .primary-detail {
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .matrix {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding-top: var(--space-xs);
    border-top: 1px solid var(--color-border);
    font-size: 0.875rem;
  }

  .matrix-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .matrix-row dt {
    color: var(--color-text-muted);
  }

  .matrix-row dd {
    display: flex;
    gap: var(--space-2xs);
    white-space: nowrap;
  }

  .matrix-row a {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
    text-decoration-color: var(--color-border-strong);
    text-underline-offset: 0.2em;
  }

  .matrix-row a:hover {
    color: var(--color-accent);
  }

  .sep {
    color: var(--color-border-strong);
  }

  .note {
    margin-top: auto;
    color: var(--color-text-muted);
    font-size: 0.8125rem;
  }
</style>
