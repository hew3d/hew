{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hew",
  "identifier": "com.hew.desktop",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../app dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --dir ../../app build",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hew",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
