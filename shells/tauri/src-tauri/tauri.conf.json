{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hew",
  "identifier": "com.hew.desktop",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../app dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --dir ../../app build",
    "frontendDist": "../../../app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hew",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost blob:; worker-src 'self' blob:; media-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3NTcwRjI1NjhCMDFBN0QKUldSOUdyQm9KUTlYdDl4NDhvOUN5V212bkM1cUVKK0ZOTkZENnRpN25Fek1pR3lxWFpGV3pOcloK",
      "endpoints": [
        "https://github.com/hew3d/hew/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["hew"],
        "name": "Hew Model",
        "description": "Hew 3D model file",
        "role": "Editor"
      }
    ]
  }
}
